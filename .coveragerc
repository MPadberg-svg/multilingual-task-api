[run]
source = apps
omit =
    */tests/*
    */migrations/*
    */__init__.py
    */admin.py
    config/*
    manage.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    class .*Protocol.*
    @(abc\.)?abstractmethod
